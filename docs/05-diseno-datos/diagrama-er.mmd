        bigint id PK
        string name
        string slug
        string subscription_status
    }
    USER_COMPANY_MEMBERSHIP {
        bigint id PK
        bigint user_id FK
        bigint company_id FK
        string role
        boolean is_default
        string status
    }
    TEAM {
        bigint id PK
        bigint company_id FK
        string name
    }
    TEAM_MEMBER {
        bigint id PK
        bigint team_id FK
        bigint user_id FK
    }
    PIPELINE {
        bigint id PK
        bigint company_id FK
        string name
        boolean is_default
    }
    PIPELINE_STAGE {
        bigint id PK
        bigint pipeline_id FK
        string name
        int order_index
    }
    QUESTIONNAIRE {
        bigint id PK
        bigint company_id FK
        string name
    }
    QUESTIONNAIRE_QUESTION {
        bigint id PK
        bigint questionnaire_id FK
        string question_text
        string type
    }
    SCORECARD_TEMPLATE {
        bigint id PK
        bigint company_id FK
        string name
    }
    SCORECARD_CRITERION {
        bigint id PK
        bigint scorecard_template_id FK
        string name
        int max_score
    }
