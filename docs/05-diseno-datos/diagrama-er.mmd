        bigint id PK
        bigint application_id FK
        bigint questionnaire_id FK
        string status
    }
    QUESTIONNAIRE_RESPONSE {
        bigint id PK
        bigint assignment_id FK
        bigint question_id FK
        text response_value
    }
    APPLICATION_SCORECARD {
        bigint id PK
        bigint application_id FK
        bigint scorecard_template_id FK
        bigint evaluator_user_id FK
        int total_score
    }
    APPLICATION_SCORECARD_ITEM {
        bigint id PK
        bigint application_scorecard_id FK
        bigint criterion_id FK
        int score
    }
    APPLICATION_DOCUMENT {
        bigint id PK
        bigint application_id FK
        bigint candidate_id FK
        string external_file_id
        string file_name
    }
    NOTIFICATION_LOG {
        bigint id PK
        bigint application_id FK
        string event_type
        string status
        text error_message
