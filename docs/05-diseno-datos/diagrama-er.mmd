        bigint id PK
        bigint position_id FK
        string name
        text value
        boolean secure
    }
    CANDIDATE {
        bigint id PK
        string name
        string email_address
        string phone_number
        string address
    }
    CANDIDATE_EDUCATION {
        bigint id PK
        bigint candidate_id FK
        string institution
        string degree
    }
    CANDIDATE_WORK_HISTORY {
        bigint id PK
        bigint candidate_id FK
        string company_name
        string title
    }
    APPLICATION {
        bigint id PK
        bigint candidate_id FK
        bigint company_id FK
        bigint position_id FK
        bigint current_stage_id FK
        string origin
        string source
        string status
    }
